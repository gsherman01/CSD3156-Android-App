# App
APP_NAME=GIS Cloud API
APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Storage mode: local | aws
STORAGE_PROVIDER=local
UPLOAD_DIR=data/uploads
RESULTS_DIR=data/results
METADATA_REGISTRY_PATH=data/metadata/datasets.json

# AWS settings (optional for local, required for S3 mode)
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Browser/API configuration
CORS_ORIGINS=*
