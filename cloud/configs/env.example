# this is where I change lik Macros and Env Variable.
# App
APP_NAME=GIS Cloud API
APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Storage mode: local | aws
STORAGE_PROVIDER=local
UPLOAD_DIR=data/uploads

# AWS settings (optional for local, required for S3 mode)
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
